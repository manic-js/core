{
  "name": "manicjs",
  "version": "0.7.4",
  "description": "Stupidly fast, Crazy light React framework powered by Bun and Hono",
  "keywords": [
    "bun",
    "framework",
    "fullstack",
    "hmr",
    "hono",
    "react"
  ],
  "license": "GPL-3.0",
  "author": "Rahuletto",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rahuletto/manic"
  },
  "bin": {
    "manic": "./src/cli/index.ts"
  },
  "files": [
    "index.ts",
    "src/**/*",
    "README.md"
  ],
  "type": "module",
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "import": "./index.ts"
    },
    "./router": {
      "types": "./src/router/index.ts",
      "import": "./src/router/index.ts"
    },
    "./plugins": {
      "types": "./src/plugins/index.ts",
      "import": "./src/plugins/index.ts"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "import": "./src/server/index.ts"
    },
    "./config": {
      "types": "./src/config/index.ts",
      "import": "./src/config/index.ts"
    },
    "./theme": {
      "types": "./src/theme/index.ts",
      "import": "./src/theme/index.ts"
    },
    "./env": {
      "types": "./src/env/client.ts",
      "import": "./src/env/client.ts"
    },
    "./client": {
      "types": "./src/config/client.ts",
      "import": "./src/config/client.ts"
    },
    "./transitions": {
      "types": "./src/transitions/index.ts",
      "import": "./src/transitions/index.ts"
    }
  },
  "dependencies": {
    "bun-plugin-tailwind": "^0.1.2",
    "colorette": "^2.0.20",
    "hono": "^4.7.0",
    "oxc-minify": "^0.125.0",
    "oxc-resolver": "^11.19.1",
    "oxc-transform": "^0.125.0",
    "oxlint": "^1.60.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-refresh": "^0.18.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
