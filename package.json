{
  "name": "manicjs",
  "version": "1.0.3-canary.0",
  "description": "Stupidly fast, Crazy light React framework powered by Bun and Hono",
  "keywords": [
    "bun",
    "framework",
    "fullstack",
    "hmr",
    "hono",
    "react"
  ],
  "homepage": "https://github.com/manic-js/manic#readme",
  "bugs": {
    "url": "https://github.com/manic-js/manic/issues"
  },
  "license": "GPL-3.0",
  "author": "Rahuletto",
  "repository": {
    "type": "git",
    "url": "https://github.com/manic-js/manic"
  },
  "bin": {
    "manic": "./src/cli/index.ts"
  },
  "files": [
    "index.ts",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": {
      "types": "./index.ts",
      "import": "./index.ts"
    },
    "./router": {
      "types": "./src/router/index.ts",
      "import": "./src/router/index.ts"
    },
    "./plugins": {
      "types": "./src/plugins/index.ts",
      "import": "./src/plugins/index.ts"
    },
    "./server": {
      "types": "./src/server/index.ts",
      "import": "./src/server/index.ts"
    },
    "./config": {
      "types": "./src/config/index.ts",
      "import": "./src/config/index.ts"
    },
    "./theme": {
      "types": "./src/theme/index.ts",
      "import": "./src/theme/index.ts"
    },
    "./env": {
      "types": "./src/env/client.ts",
      "import": "./src/env/client.ts"
    },
    "./client": {
      "types": "./src/config/client.ts",
      "import": "./src/config/client.ts"
    },
    "./transitions": {
      "types": "./src/transitions/index.ts",
      "import": "./src/transitions/index.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "validate": "bunx --bun oxlint --config .oxlintrc.json src && bunx --bun oxfmt --check --config .oxfmt.json src",
    "test:cli": "bun test ./tests/cli/cli-commands.test.ts",
    "test:e2e": "bun test ./tests/integration/demo-workflow.test.ts",
    "test:framework": "cd ../../demo && bun run build",
    "ci:lint": "bunx --bun oxlint --config .oxlintrc.json .",
    "ci:format": "bunx --bun oxfmt --check --config .oxfmt.json .",
    "ci:typecheck": "if [ -f tsconfig.json ]; then bunx --bun tsc --noEmit; elif [ -f src/index.ts ]; then bunx --bun tsc --noEmit --module esnext --moduleResolution bundler --target es2022 src/index.ts; elif [ -f index.ts ]; then bunx --bun tsc --noEmit --module esnext --moduleResolution bundler --target es2022 index.ts; else echo \"No TypeScript entrypoint found\"; exit 1; fi",
    "ci:build": "if bun run | grep -q \"^ build$\"; then bun run build; elif [ -f src/index.ts ]; then bun build src/index.ts --target bun --outdir .ci-build; elif [ -f index.ts ]; then bun build index.ts --target bun --outdir .ci-build; else echo \"No build entrypoint found\"; exit 1; fi",
    "ci:test": "bun run test:cli && bun run test:e2e",
    "ci:compliance": "test -f CODE_OF_CONDUCT.md && test -f LICENSE && test -f README.md",
    "test": "bun run test:cli",
    "test:integration": "bun run test:e2e"
  },
  "dependencies": {
    "@manicjs/bundler": "0.0.0-canary.1",
    "@manicjs/tui": "1.0.2-canary.0",
    "bun-plugin-tailwind": "^0.1.2",
    "hono": "^4.12.18",
    "kill-port": "^2.0.1",
    "oxc-minify": "^0.129.0",
    "oxc-resolver": "^11.19.1",
    "oxc-transform": "^0.129.0",
    "oxlint": "^1.63.0"
  },
  "devDependencies": {
    "@shikijs/transformers": "^4.0.2",
    "@types/bun": "^1.3.13",
    "@types/mdx": "^2.0.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "fumadocs-docgen": "^3.0.10",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-refresh": "^0.18.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
